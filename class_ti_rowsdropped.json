{
    "seed": 42,
    "name": "ClassificationModel",
    "plot": false,
    "run_val": 1,
    "model":
    {
        "input_shape": 28,
        "output_shape": 1
    },
    "optimizer":
    {
        "lr": 0.0001
    },
    "num_epochs": 5,
    "dataloader":
    {
        "scale": true,
        "feature_scale": [-1, 1],
        "label_scale": [-1, 1],

        "ignore_columns": ["shot", "time_until_disrupt"],
        "label_column": "disruptive",
        "data_split": [0.7, 0.15, 0.15],

        "batch_sizes":
        {
            "training": 128,
            "testing": 128,
            "validation": 128
        }
    },
    "output":
    {
        "dir":"./",
        "filename":"classification_data"
    }
}